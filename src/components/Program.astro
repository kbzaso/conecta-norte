---
import Badge from "./Badge.astro";
---

<section id="el-programa" class="relative bg-north overflow-hidden scroll-mt-10">
  <div class="absolute inset-0 bg-linear-to-br from-north via-north to-[#1e1435]"></div>

  <!-- Decorative blobs -->
  <div
    class="absolute top-1/4 -left-24 w-md h-112 rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(96,59,255,0.12) 0%, transparent 70%);"
  ></div>
  <div
    class="absolute bottom-0 right-0 w-88 h-88 rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(51,45,249,0.1) 0%, transparent 70%);"
  ></div>

  <div class="max-w-300 mx-auto px-8 py-24 lg:px-16 relative z-10">

    <!-- Header + Description -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start mb-20">
      <div>
        <span class="block text-[0.75rem] font-medium tracking-[0.15em] uppercase text-accent mb-4">
          El Programa
        </span>
        <h2 class="font-black text-[clamp(2rem,3.5vw,3rem)] leading-[1.1] text-white mb-6">
          Una experiencia formativa para la
          <em class="italic font-light text-sand/80"> transformación digital</em>
        </h2>
      </div>
      <div class="flex flex-col gap-4 lg:pt-14">
        <p class="text-[1.05rem] leading-[1.75] text-sand/65">
          Conecta Norte ofrece una experiencia formativa diseñada para desarrollar habilidades tecnológicas relevantes para la transformación digital de la industria.
        </p>
        <p class="text-[1.05rem] leading-[1.75] text-sand/65">
          Durante el programa, los estudiantes participan en un proceso de aprendizaje que combina formación online, aprendizaje práctico, mentorías y trabajo colaborativo.
        </p>
      </div>
    </div>

    <!-- Roadmap Infographic -->
    <div class="relative">

      <!-- Nodes grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 relative z-10">
        {
          [
            {
              num: "01",
              label: "Formación online",
              desc: "Contenidos digitales accesibles desde cualquier lugar, adaptados al ritmo de cada estudiante.",
              icon: `<svg  xmlns="http://www.w3.org/2000/svg" width="24" height="24"
fill="currentColor" viewBox="0 0 24 24" >
<!--Boxicons v3.0.8 https://boxicons.com | License  https://docs.boxicons.com/free-->
<path d="M20 14h-5v-1h4c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v7c0 1.1.9 2 2 2h4v1H4c-1.1 0-2 .9-2 2v4c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2v-4c0-1.1-.9-2-2-2M5 11V4h14v7zm-1 9v-4h16v4z"></path><path d="M6 17h8v2H6zm11 0a1 1 0 1 0 0 2 1 1 0 1 0 0-2"></path>
</svg>`,
              color: "from-sky/30 to-sky/10",
              dot: "bg-sky",
            },
            {
              num: "02",
              label: "Aprendizaje práctico",
              desc: "Ejercicios y proyectos aplicados a desafíos reales de la industria tecnológica regional.",
              icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 24 24"><path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/></svg>`,
              color: "from-electric/30 to-electric/10",
              dot: "bg-electric",
            },
            {
              num: "03",
              label: "Mentorías",
              desc: "Acompañamiento personalizado por profesionales activos con experiencia en transformación digital.",
              icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>`,
              color: "from-verde/30 to-verde/10",
              dot: "bg-verde",
            },
            {
              num: "04",
              label: "Trabajo colaborativo",
              desc: "Equipos multidisciplinarios que desarrollan soluciones conjuntas, fortaleciendo habilidades blandas y técnicas.",
              icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>`,
              color: "from-accent/30 to-accent/10",
              dot: "bg-accent",
            },
          ].map(({ num, label, desc, icon, color, dot }, index) => (
            <div class="flex flex-col items-center text-left group relative">
              <div class="bg-white/4 border border-sand/10 rounded-md p-6 w-full transition-[background,transform] duration-300 group-hover:bg-sky/10 group-hover:border-sky/20">
                <span class="text-[1rem] font-bold text-sand mb-2">{label}</span>
                <p class="text-[0.85rem] leading-[1.65] text-sand/50">{desc}</p>
              </div>
              <!-- Mobile vertical connector -->
              {index < 3 && (
                <div class="block sm:hidden absolute top-full left-1/2 -translate-x-1/2 w-px h-6 bg-linear-to-b from-sky/40 to-sky/10" />
              )}
              <!-- Desktop horizontal connector -->
              {index < 3 && (
                <div class="hidden lg:block absolute left-full top-1/2 -translate-y-1/2 w-6 h-px bg-linear-to-r from-sky/40 to-sky/10" />
              )}
            </div>
          ))
        }
      </div>
<div class="mt-10">
      <Badge number="6" title="meses de duración total" description="programa intensivo de formación" />
      </div>
    </div>
  </div>
</section>
