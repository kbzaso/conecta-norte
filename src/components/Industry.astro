---
import { Image } from "astro:assets";
import group from "../assets/colaboracion2.webp";
import CTAIndustry from "./CTAIndustry.astro";
---

<section id="aliados" class="relative bg-surface overflow-hidden">
  <div class="max-w-300 mx-auto px-8 py-24 lg:px-16">
    <div class="flex flex-col lg:flex-row items-end gap-12 mb-16">
         <div class="text-center md:text-left w-full lg:w-1/2">
        <span
          class="block text-[0.75rem] font-medium tracking-[0.15em] uppercase text-sky mb-4"
          >05 — Industria y Aliados</span
        >
        <h2 class="font-black text-[clamp(2rem,3.5vw,3rem)] leading-[1.1] mb-6">
          Las industrias que impulsan el norte
        </h2>
        <p class="text-[1.05rem] leading-[1.75] text-north/70 mx-auto">
          Conecta Norte existe gracias a alianzas concretas entre industria,
          instituciones tecnológicas y actores del territorio. Juntos diseñamos
          formación alineada con las necesidades reales del mercado laboral,
          abriendo oportunidades para los jóvenes que construirán el futuro
          digital del norte de Chile.
        </p>
      </div>
      <!-- Full-width image -->
      <div class="w-full lg:w-1/2">
        <Image
          src={group}
          alt="Jóvenes colaborando en el programa Conecta Norte"
          class="object-cover rounded-2xl"
        />
      </div>

     
    </div>
    <CTAIndustry />
  </div>
</section>
