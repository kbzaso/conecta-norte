<section id="postulacion" class="relative bg-north overflow-hidden">
  <div
    class="absolute w-150 h-150 rounded-full bg-[radial-gradient(circle,rgba(96,59,255,0.25)_0%,transparent_70%)] -top-[200px] -right-[200px] pointer-events-none"
