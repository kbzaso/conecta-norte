---
import Image from "astro/components/Image.astro";
import heroModel from "../assets/hero-model.webp";
import desert from "../assets/desierto.webp";
const textureStyle = `background-image:url(${desert})`;
---

<section
  id="inicio"
  class="relative min-h-screen bg-north items-center flex overflow-hidden pt-25"
>
<div class="w-full h-full absolute inset-0">
  <Image
    src={desert}
    alt="Textura de fondo"
    class="absolute inset-0 w-full h-full object-cover opacity-40 pointer-events-none hero"
  />
</div>
  <div class="flex mx-auto w-full max-w-300 justify-between">
    <div class="px-8 py-8 lg:py-24 relative z-10 mx-auto md:mx-0">
      <div
        class="block text-center md:text-left text-xs font-medium tracking-wide uppercase text-accent bg-north/90 px-4 py-[0.4rem] rounded-full mb-8 animate-fade-up animation-delay:0.1s md:inline-block"
      >
        ✦ Programa de Vinculación 2026
      </div>
      <h1
        class="font-black text-3xl md:text-5xl lg:text-6xl leading-none text-white mb-6 animate-fade-up animation-delay:0.25s text-center md:text-left"
      >
        <em class="italic font-light text-sand">El norte es el futuro</em><br
        />Nosotros el puente
      </h1>
      <p
        class="text-[1.1rem] leading-[1.7] text-sand max-w-120 mb-12 animate-fade-up animation-delay:0.4s text-center md:text-left"
      >
        Formamos a la próxima generación de especialistas tecnológicos
        conectando a jóvenes del territorio con las oportunidades de la
        industria minera y el ecosistema digital.
      </p>
      <div
        class="flex flex-col md:flex-row gap-4 items-center animate-fade-up animation-delay:0.55s"
      >
        <a
          href="#postulacion"
          class="bg-accent text-north font-bold text-sm tracking-[0.05em] uppercase px-8 py-4 rounded-sm no-underline inline-block transition-[transform,box-shadow] duration-200 hover:-translate-y-0.5 hover:shadow-[0_10px_30px_rgba(240,165,0,0.3)]"
          >Postular ahora →</a
        >
        <a
          href="#que-es"
          class="text-sand text-sm font-medium no-underline flex items-center gap-2 transition-[gap] duration-200 hover:gap-3"
          >Conoce el programa <span>↓</span></a
        >
      </div>
    </div>

    <div class="hidden md:flex z-10 justify-center items-center">
      <div class="relative w-90 h-105">
        <Image
          src={heroModel}
          alt="Imagen de bienvenida"
          class="absolute -top-28 lg:right-20 z-0 animate-float hero scale-125"
        />
        <div
          class="absolute h-fit top-30 right-16 bg-gradient-to-br from-sky/35 to-north/85 border border-sand/15 rounded-3xl px-6 py-4 backdrop-blur-md animate-float-card"
        >
          <div class="font-black text-[2.5rem] leading-none text-white mb-1">
            +600
          </div>
          <div class="text-[0.7rem] uppercase tracking-widest text-sand/50">
            Estudiantes en formación
          </div>
        </div>
        <div
          class="absolute h-fit w-66 top-60 right-0 bg-gradient-to-br from-sky/35 to-north/85 border border-sand/15 rounded-3xl px-6 py-4 backdrop-blur-md animate-float-card"
        >
          <div class="font-black text-[2.5rem] leading-none text-white mb-1">
            300
          </div>
          <div
            class="text-[0.7rem] uppercase tracking-widest text-sand/50"
          >
            Estudiantes en formación
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    mask-image: linear-gradient(black 40%, transparent 90%, transparent);
  }
</style>
